rules_version = '2';

// Hackathon-friendly rules: authenticated users (anonymous auth) can read/write.
// Tighten before production — cases contain sensitive document metadata.
service cloud.firestore {
  match /databases/{database}/documents {
    // Public law reference data — readable without auth so pipeline works offline.
    match /knowledgeBase/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /collectiveCases/{clusterId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /cases/{caseId} {
      allow read, write: if request.auth != null;
    }

    match /followUps/{followUpId} {
      allow read, write: if request.auth != null;
    }
  }
}
