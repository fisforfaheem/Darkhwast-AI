# Copy to `.env` and fill in (never commit `.env`).
# API key: https://aistudio.google.com/apikey
# Models:  https://ai.google.dev/gemini-api/docs/models

GEMINI_API_KEY=your_gemini_api_key_here

# Recommended models (May 2026):
#   gemini-2.5-pro              — stable GA, best for production / hackathon demo
#   gemini-3.1-pro-preview      — latest, optimized for multi-step agents (preview)
#   gemini-2.5-flash            — faster, lower cost
GEMINI_MODEL=gemini-3.1-pro-preview

# Set true only for offline judge demo without calling Gemini.
USE_MOCK=false
